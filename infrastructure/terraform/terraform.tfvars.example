# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit it (contains secrets).

# Your registered domain name (must exist in Route 53 or be transferred there)
domain_name = "onetogether.sg"

# Master password for the RDS PostgreSQL database
# Use a strong password: at least 16 chars, letters + numbers + symbols
db_password = "REPLACE_WITH_STRONG_PASSWORD"

# Email address that receives emergency alert notifications via SNS
alert_email = "alerts@onetogether.sg"

# Optional overrides (defaults are set in variables.tf)
# aws_region             = "ap-southeast-1"
# environment            = "production"
# eks_node_instance_type = "t3.medium"
# eks_desired_nodes      = 2
# eks_min_nodes          = 2
# eks_max_nodes          = 6
# db_instance_class      = "db.t3.medium"
# elasticache_node_type  = "cache.t3.micro"
