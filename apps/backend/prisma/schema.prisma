generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  role           String   @default("citizen")
  organisationId String?
  createdAt      DateTime @default(now())

  organisation Organisation? @relation(fields: [organisationId], references: [id])
  messages     ChatMessage[]
  uploads      IncidentUpload[]
}

model Organisation {
  id                  String @id @default(cuid())
  name                String
  type                String @default("Government")
  address             String @default("")
  verified            Boolean @default(false)
  volunteersAvailable Int     @default(0)
  volunteersTotal     Int     @default(0)
  activeTasks         Int     @default(0)
  status              String  @default("active")

  users   User[]
  units   ResourceUnit[]
}

model Incident {
  id               String   @id @default(cuid())
  title            String
  type             String
  severity         String
  status           String   @default("Reported")
  description      String   @default("")
  location         String
  zone             String   @default("")
  publicVisibility String   @default("Private")
  createdBy        String
  incidentCommander String?
  confidenceScore  Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // JSON-serialised string: ["scdf","spf"]
  assignedOrgIds   String   @default("[]")

  latitude        Float?
  longitude       Float?
  boundaryGeoJson String?

  timeline     TimelineEvent[]
  messages     ChatMessage[]
  resources    ResourceAssignment[]
  uploads      IncidentUpload[]
  participants IncidentParticipant[]
  reports      Report[]
  pois         IncidentPOI[]
}

model Report {
  id          String    @id @default(cuid())
  incidentId  String
  title       String    @default("Incident Report")
  content     String    @default("")
  status      String    @default("draft")
  version     Int       @default(1)
  createdBy   String
  createdByName String  @default("")
  finalizedBy String?
  finalizedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
}

model TimelineEvent {
  id           String   @id @default(cuid())
  incidentId   String
  timestamp    DateTime @default(now())
  actor        String?
  organisation String?
  category     String
  text         String
  latitude     Float?
  longitude    Float?

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id         String   @id @default(cuid())
  incidentId String
  senderId   String?
  senderName String
  senderRole String?
  content    String
  isAi       Boolean  @default(false)
  aiCommand  String?
  createdAt  DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  sender   User?    @relation(fields: [senderId], references: [id])
}

model ResourceUnit {
  id             String @id @default(cuid())
  callSign       String
  type           String
  status         String @default("Available")
  organisationId String
  lastKnownLat   Float?
  lastKnownLng   Float?

  organisation Organisation       @relation(fields: [organisationId], references: [id])
  assignments  ResourceAssignment[]
}

model ResourceAssignment {
  id         String   @id @default(cuid())
  incidentId String
  unitId     String
  status     String   @default("Assigned")
  assignedAt DateTime @default(now())
  notes      String?

  incident Incident     @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  unit     ResourceUnit @relation(fields: [unitId], references: [id])

  @@unique([incidentId, unitId])
}

model IncidentUpload {
  id           String   @id @default(cuid())
  incidentId   String
  uploadedBy   String
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String
  caption      String?
  latitude     Float?
  longitude    Float?
  createdAt    DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [uploadedBy], references: [id])
}

model IncidentPOI {
  id          String   @id @default(cuid())
  incidentId  String
  title       String
  description String?
  latitude    Float
  longitude   Float
  type        String   @default("OTHER")
  createdBy   String
  createdAt   DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
}

model IncidentParticipant {
  incidentId String
  userId     String
  userName   String
  joinedAt   DateTime @default(now())
  lastSeenAt DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@id([incidentId, userId])
}
