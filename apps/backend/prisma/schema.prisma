generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model assigned_orgs {
  incident_id     String        @db.Uuid
  organisation_id String        @db.Uuid
  assigned_at     DateTime      @default(now()) @db.Timestamptz(6)
  unit_name       String        @default("Response Unit") @db.VarChar(120)
  status          String        @default("DISPATCHED") @db.VarChar(20)
  notes           String        @default("")
  incidents       incidents     @relation(fields: [incident_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organisations   organisations @relation(fields: [organisation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([incident_id, organisation_id])
  @@index([incident_id], map: "idx_assigned_orgs_incident_id")
  @@index([organisation_id], map: "idx_assigned_orgs_organisation_id")
  @@index([status], map: "idx_assigned_orgs_status")
}

model discussions {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  incident_id String     @db.Uuid
  title       String     @db.VarChar(255)
  created_at  DateTime   @default(now()) @db.Timestamptz(6)
  updated_at  DateTime   @default(now()) @db.Timestamptz(6)
  incidents   incidents  @relation(fields: [incident_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  messages    messages[]

  @@index([created_at], map: "idx_discussions_created_at")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model incident_sources {
  incident_id        String    @db.Uuid
  external_ticket_id String
  last_synced_at     DateTime  @default(now()) @db.Timestamptz(6)
  incidents          incidents @relation(fields: [incident_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([incident_id, external_ticket_id])
  @@index([incident_id], map: "idx_incident_sources_incident_id")
}

model incidents {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code             String             @unique @db.VarChar(10)
  title            String
  incident_type    String             @db.VarChar(50)
  severity         Int
  inc_status       String             @db.VarChar(50)
  inc_description  String?
  inc_location     String?
  report           String?
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @default(now()) @db.Timestamptz(6)
  resolved_at      DateTime?          @db.Timestamptz(6)
  confidence_score Int?
  lat              Float?
  lng              Float?
  assigned_orgs    assigned_orgs[]
  discussions      discussions[]
  incident_sources incident_sources[]
  logs             logs[]
  resources        incident_resources[]

  @@index([code], map: "idx_incidents_code")
  @@index([created_at], map: "idx_incidents_created_at")
  @@index([inc_status], map: "idx_incidents_status")
  @@index([title], map: "idx_incidents_title")
  @@index([lat, lng], map: "idx_incidents_geo")
}

model incident_resources {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  incident_id    String    @db.Uuid
  unit_ref       String    @db.VarChar(60)
  agency         String    @db.VarChar(50)
  resource_kind  String    @db.VarChar(30)
  status         String    @db.VarChar(20)
  origin_station String?   @db.VarChar(60)
  origin_lat     Float?
  origin_lng     Float?
  eta_minutes    Int?
  eta_at         DateTime? @db.Timestamptz(6)
  dispatched_at  DateTime  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime  @default(now()) @db.Timestamptz(6)
  notes          String?
  incidents      incidents @relation(fields: [incident_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([incident_id, unit_ref], map: "uq_incident_resources_incident_unit")
  @@index([incident_id], map: "idx_incident_resources_incident_id")
  @@index([status], map: "idx_incident_resources_status")
}

model logs {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  incident_id String    @db.Uuid
  content     String
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  incidents   incidents @relation(fields: [incident_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model messages {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  discussion_id  String      @db.Uuid
  sender_id      String      @db.Uuid
  parent_id      String?     @db.Uuid
  body           String
  created_at     DateTime    @default(now()) @db.Timestamptz(6)
  discussions    discussions @relation(fields: [discussion_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  messages       messages?   @relation("messagesTomessages", fields: [parent_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  other_messages messages[]  @relation("messagesTomessages")
  users          users       @relation(fields: [sender_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([created_at], map: "idx_messages_created_at")
  @@index([discussion_id], map: "idx_messages_discussion_id")
  @@index([parent_id], map: "idx_messages_parent_id")
  @@index([sender_id], map: "idx_messages_sender_id")
}

model organisations {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_name            String                @unique @db.VarChar(50)
  assigned_orgs       assigned_orgs[]
  broadcast_audiences broadcast_audiences[]
  user_organisations  user_organisations[]
  volunteer_sources   volunteer_sources[]
}

model resources {
  id            String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resource_name String @unique @db.VarChar(50)
  capacity      Int
  available     Int
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model users {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username           String               @unique @db.VarChar(50)
  email              String               @unique @db.VarChar(255)
  first_name         String?              @db.VarChar(100)
  last_name          String?              @db.VarChar(100)
  phone              String?              @db.VarChar(20)
  is_verified        Boolean              @default(false)
  role               String               @default("user") @db.VarChar(20)
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  updated_at         DateTime             @default(now()) @db.Timestamptz(6)
  last_login         DateTime?            @db.Timestamptz(6)
  accounts           accounts?
  broadcasts         broadcasts[]
  messages           messages[]
  user_organisations user_organisations[]

  @@index([created_at], map: "idx_users_created_at")
  @@index([email], map: "idx_users_email")
  @@index([role], map: "idx_users_role")
  @@index([username], map: "idx_users_username")
}

model notifications {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                   String                    @db.VarChar(120)
  message                 String
  notification_type       String                    @db.VarChar(50)
  reference_type          String?                   @db.VarChar(50)
  reference_id            String?                   @db.Uuid
  created_at              DateTime                  @default(now()) @db.Timestamptz(6)
  notification_recipients notification_recipients[]

  @@index([created_at], map: "idx_notifications_created_at")
  @@index([notification_type], map: "idx_notifications_type")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model notification_recipients {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  notification_id String        @db.Uuid
  recipient_type  String        @db.VarChar(20)
  recipient_id    String?       @db.Uuid
  recipient_role  String?       @db.VarChar(50)
  is_read         Boolean       @default(false)
  read_at         DateTime?     @db.Timestamptz(6)
  notifications   notifications @relation(fields: [notification_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([is_read], map: "idx_notification_recipients_is_read")
  @@index([notification_id], map: "idx_notification_recipients_notification_id")
  @@index([recipient_type, recipient_id, recipient_role], map: "idx_notification_recipients_recipient")
}

model accounts {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String           @unique @db.Uuid
  password_hash  String           @db.VarChar(255)
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  updated_at     DateTime         @default(now()) @db.Timestamptz(6)
  users          users            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  refresh_tokens refresh_tokens[]

  @@index([user_id], map: "idx_accounts_user_id")
}

model refresh_tokens {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  account_id         String    @db.Uuid
  refresh_token_hash String
  created_at         DateTime  @default(now()) @db.Timestamptz(6)
  expires_at         DateTime  @db.Timestamptz(6)
  revoked_at         DateTime? @db.Timestamptz(6)
  accounts           accounts  @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([account_id], map: "idx_refresh_tokens_account_id")
  @@index([expires_at], map: "idx_refresh_tokens_expires_at")
  @@index([revoked_at], map: "idx_refresh_tokens_revoked_at")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model broadcast_audiences {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  broadcast_id    String         @db.Uuid
  audience_type   String         @db.VarChar(20)
  audience_role   String?        @db.VarChar(50)
  organisation_id String?        @db.Uuid
  region          String?        @db.VarChar(100)
  broadcasts      broadcasts     @relation(fields: [broadcast_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organisations   organisations? @relation(fields: [organisation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([broadcast_id], map: "idx_broadcast_audiences_broadcast_id")
  @@index([audience_type, audience_role, organisation_id, region], map: "idx_broadcast_audiences_target")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model broadcasts {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title               String                @db.VarChar(120)
  message             String
  broadcast_type      String                @db.VarChar(50)
  severity            String                @default("info") @db.VarChar(20)
  broadcast_status    String                @default("draft") @db.VarChar(20)
  created_by_user_id  String?               @db.Uuid
  published_at        DateTime?             @db.Timestamptz(6)
  archived_at         DateTime?             @db.Timestamptz(6)
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  updated_at          DateTime              @default(now()) @db.Timestamptz(6)
  broadcast_audiences broadcast_audiences[]
  users               users?                @relation(fields: [created_by_user_id], references: [id], onUpdate: NoAction)

  @@index([created_at], map: "idx_broadcasts_created_at")
  @@index([severity], map: "idx_broadcasts_severity")
  @@index([broadcast_status], map: "idx_broadcasts_status")
  @@index([broadcast_type], map: "idx_broadcasts_type")
}

model user_organisations {
  user_id         String        @db.Uuid
  organisation_id String        @db.Uuid
  created_at      DateTime      @default(now()) @db.Timestamptz(6)
  organisations   organisations @relation(fields: [organisation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users           users         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, organisation_id])
  @@index([organisation_id], map: "idx_user_organisations_organisation_id")
  @@index([user_id], map: "idx_user_organisations_user_id")
}

model volunteer_opportunities {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source_id           String            @db.Uuid
  external_id         String
  title               String            @db.VarChar(150)
  description         String?
  opportunity_type    String?           @db.VarChar(50)
  location            String?
  region              String?           @db.VarChar(100)
  start_at            DateTime?         @db.Timestamptz(6)
  end_at              DateTime?         @db.Timestamptz(6)
  signup_url          String
  source_url          String?
  external_updated_at DateTime?         @db.Timestamptz(6)
  opportunity_status  String            @default("open") @db.VarChar(30)
  created_at          DateTime          @default(now()) @db.Timestamptz(6)
  updated_at          DateTime          @default(now()) @db.Timestamptz(6)
  volunteer_sources   volunteer_sources @relation(fields: [source_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([source_id, external_id])
  @@index([region], map: "idx_volunteer_opportunities_region")
  @@index([source_id], map: "idx_volunteer_opportunities_source_id")
  @@index([start_at], map: "idx_volunteer_opportunities_start_at")
  @@index([opportunity_status], map: "idx_volunteer_opportunities_status")
  @@index([opportunity_type], map: "idx_volunteer_opportunities_type")
}

model volunteer_sources {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source_name             String                    @db.VarChar(100)
  source_url              String                    @unique
  organisation_id         String?                   @db.Uuid
  is_active               Boolean                   @default(true)
  last_synced_at          DateTime?                 @db.Timestamptz(6)
  created_at              DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at              DateTime                  @default(now()) @db.Timestamptz(6)
  volunteer_opportunities volunteer_opportunities[]
  organisations           organisations?            @relation(fields: [organisation_id], references: [id], onUpdate: NoAction)

  @@index([is_active], map: "idx_volunteer_sources_active")
  @@index([organisation_id], map: "idx_volunteer_sources_organisation_id")
}
